# Environment Variables Configuration

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///grievances.db
# For PostgreSQL: postgresql://username:password@localhost:5432/civicflow

# Email Configuration (Gmail Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@civicflow.com
DEFAULT_ADMIN_EMAIL=admin@civicflow.com

# Application Configuration
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_NAME=CivicFlow Grievance Hub
APP_VERSION=1.0.0

# SMS Configuration (Twilio - Optional)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Admin Credentials (Change in production)
ADMIN_EMAIL=admin@civicflow.com
ADMIN_PASSWORD=admin123

# JWT Configuration (Future)
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION=3600

# File Upload Configuration
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# API Rate Limiting (Future)
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Environment
ENVIRONMENT=development
# development, staging, production
