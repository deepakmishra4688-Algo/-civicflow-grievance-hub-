FROM node:18-slim

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY src/ src/
COPY public/ public/
COPY vite.config.js index.html ./

ENV REACT_APP_API_URL=http://backend:5000/api

RUN npm run build
RUN npm install -g serve

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
